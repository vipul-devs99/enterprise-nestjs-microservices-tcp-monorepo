{
  "name": "reviews-microservice-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["reviews-microservice"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/reviews-microservice-e2e/jest.config.ts",
        "passWithNoTests": true
      },
      "dependsOn": ["reviews-microservice:build"]
    }
  }
}
